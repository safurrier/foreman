#!/usr/bin/env -S uv run python
# MISE description="Opt-in real harness E2E drill for Claude, Codex, and Pi"
# MISE depends=["setup"]
import os
import subprocess
import sys

sys.path.insert(0, os.path.join(os.environ["MISE_PROJECT_ROOT"], "scripts"))
from lib import PROJECT_ROOT, log_ok, log_step  # noqa: E402

CASES = [
    ("FOREMAN_REAL_CLAUDE_E2E", "claude_real_e2e"),
    ("FOREMAN_REAL_CODEX_E2E", "codex_real_e2e"),
    ("FOREMAN_REAL_PI_E2E", "pi_real_e2e"),
]


def run(test_name: str) -> None:
    result = subprocess.run(
        ["cargo", "test", "--test", test_name, "--", "--ignored", "--nocapture"],
        cwd=PROJECT_ROOT,
    )
    if result.returncode != 0:
        sys.exit(result.returncode)


log_step("Running opt-in real harness drill")

ran_any = False
for env_var, test_name in CASES:
    if os.environ.get(env_var):
        log_step(f"{test_name} enabled via {env_var}")
        run(test_name)
        ran_any = True
    else:
        log_step(f"Skipping {test_name} ({env_var} not set)")

if not ran_any:
    log_step("No real harness E2Es were enabled")

log_ok("Native harness drill complete")
