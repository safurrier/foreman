import os
import subprocess
import sys

sys.path.insert(0, os.path.join(os.environ["MISE_PROJECT_ROOT"], "scripts"))
from lib import PROJECT_ROOT  # noqa: E402

task = PROJECT_ROOT / ".mise" / "tasks" / "check"
result = subprocess.run([sys.executable, str(task)], cwd=PROJECT_ROOT)
if result.returncode != 0:
    sys.exit(result.returncode)
