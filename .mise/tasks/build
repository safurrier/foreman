#!/usr/bin/env -S uv run python
# MISE description="Build release binaries"
# MISE depends=["setup"]
import os
import sys

sys.path.insert(0, os.path.join(os.environ["MISE_PROJECT_ROOT"], "scripts"))
from lib import PROJECT_ROOT, log_ok, log_step, run  # noqa: E402

log_step("Building Rust binaries")
run(["cargo", "build", "--release", "--bins"], cwd=PROJECT_ROOT)
log_ok("Rust build")
