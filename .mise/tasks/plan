#!/usr/bin/env -S uv run python
# MISE description="Legacy plan shim; start new work with Harness Kit"
from __future__ import annotations

import os
import re
import subprocess
import sys

sys.path.insert(0, os.path.join(os.environ["MISE_PROJECT_ROOT"], "scripts"))
from lib import PROJECT_ROOT, log_error, log_step, log_warn  # noqa: E402

SLUG_RE = re.compile(r"^[a-z0-9]+(?:-[a-z0-9]+)*$")


def current_branch() -> str:
    result = subprocess.run(
        ["git", "symbolic-ref", "--quiet", "--short", "HEAD"],
        cwd=PROJECT_ROOT,
        capture_output=True,
        text=True,
    )
    return result.stdout.strip() if result.returncode == 0 else ""


def main() -> None:
    args = sys.argv[1:]
    if not args:
        log_error("Usage: mise run plan -- <slug>")
        log_error("This repo has migrated new work to Harness Kit.")
        log_error("  hk start <slug> --plan 'Describe the intended change' --target .")
        sys.exit(1)

    slug = args[0].strip()
    if not SLUG_RE.fullmatch(slug):
        log_error(
            "Invalid slug: use lowercase letters, digits, and single hyphens "
            "(example: add-user-auth)"
        )
        sys.exit(1)

    branch = current_branch()
    if not branch:
        log_error("No git branch detected. Initialize git and create a feature branch first.")
        sys.exit(1)
    if branch in ("main", "master"):
        log_error(f"You're on '{branch}'. Create a feature branch before starting work.")
        log_error(f"  git checkout -b feat/{slug}")
        sys.exit(1)

    log_step("Foreman has migrated new work from .ai/plans to Harness Kit")
    print("Run:")
    print()
    print(f"  hk start {slug} --plan 'Describe the intended change and validation approach' --target .")
    print("  hk checks --target . --changed --json")
    print("  hk validate --check <name> --why 'Why this proves the slice' -- <command>")
    print("  hk sync --target .")
    print("  hk ready --target .")
    print("  WORK_ID=$(hk status --target . --json | python3 -c 'import json,sys; print(json.load(sys.stdin)[\"active_work\"])')")
    print("  hk export --format handoff-dir --output \".ai/hk/$WORK_ID\" --target .")
    print()
    log_warn("Legacy .ai/plans templates remain for historical plan maintenance only.")
    sys.exit(1)


main()
