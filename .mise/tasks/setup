#!/usr/bin/env -S uv run python
# MISE description="Fetch Rust dependencies and install local hooks"
import os
import shutil
import sys

sys.path.insert(0, os.path.join(os.environ["MISE_PROJECT_ROOT"], "scripts"))
from lib import PROJECT_ROOT, log_ok, log_step, run  # noqa: E402

log_step("Fetching Rust dependencies")
if (PROJECT_ROOT / "Cargo.toml").exists():
    run(["cargo", "fetch"], cwd=PROJECT_ROOT)
log_ok("Rust dependencies fetched")

# Install pre-commit hooks if available
pre_commit_cfg = PROJECT_ROOT / ".pre-commit-config.yaml"
git_dir = PROJECT_ROOT / ".git"
if pre_commit_cfg.exists() and shutil.which("pre-commit") and git_dir.exists():
    log_step("Installing pre-commit hooks")
    run(["pre-commit", "install"])
    log_ok("Pre-commit hooks installed")
