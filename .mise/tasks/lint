import os
import sys

sys.path.insert(0, os.path.join(os.environ["MISE_PROJECT_ROOT"], "scripts"))
from lib import PROJECT_ROOT, log_ok, log_step, run  # noqa: E402

log_step("Linting Rust code")
run(
    ["cargo", "clippy", "--all-targets", "--all-features", "--", "-D", "warnings"],
    cwd=PROJECT_ROOT,
)
log_ok("Rust lint")
