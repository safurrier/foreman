#!/usr/bin/env -S uv run python
# MISE description="Serve documentation locally (MkDocs)"
import os
import subprocess
import sys

sys.path.insert(0, os.path.join(os.environ["MISE_PROJECT_ROOT"], "scripts"))
from lib import PROJECT_ROOT, log_step  # noqa: E402

log_step("Starting MkDocs dev server")
result = subprocess.run(
    ["uv", "run", "mkdocs", "serve"],
    cwd=PROJECT_ROOT,
)
sys.exit(result.returncode)
