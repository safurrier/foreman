#!/usr/bin/env -S uv run python
# MISE description="Format Rust code"
# MISE depends=["setup"]
import os
import subprocess
import sys

sys.path.insert(0, os.path.join(os.environ["MISE_PROJECT_ROOT"], "scripts"))
from lib import PROJECT_ROOT, log_error, log_ok, log_step, run  # noqa: E402

check = "--check" in sys.argv[1:]

if check:
    log_step("Checking Rust formatting")
    result = subprocess.run(
        ["cargo", "fmt", "--check"],
        capture_output=True,
        text=True,
        cwd=PROJECT_ROOT,
    )
    if result.returncode != 0:
        log_error("Rust files need formatting:")
        print(result.stdout + result.stderr)
        sys.exit(1)
else:
    log_step("Formatting Rust code")
    run(["cargo", "fmt"], cwd=PROJECT_ROOT)

log_ok("Rust format")
