#!/usr/bin/env -S uv run python
# MISE description="UX verification: focused dashboard smoke plus optional VHS artifact refresh"
# MISE depends=["setup"]
import os
import shlex
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

sys.path.insert(0, os.path.join(os.environ["MISE_PROJECT_ROOT"], "scripts"))
from lib import PROJECT_ROOT, log_ok, log_step  # noqa: E402

ARTIFACT_DIR = (
    PROJECT_ROOT / ".ai" / "plans" / "2026-04-10-110931-tui-ux-diagnostic" / "artifacts"
)
VISUAL_ENV_PATH = ARTIFACT_DIR / "visual-env.txt"
TAPE_PATH = ARTIFACT_DIR / "foreman-ux-diagnostic.tape"


def run(command: list[str], *, cwd: Path = PROJECT_ROOT) -> None:
    result = subprocess.run(command, cwd=cwd)
    if result.returncode != 0:
        sys.exit(result.returncode)


def tmux(socket_path: Path, *args: str) -> str:
    result = subprocess.run(
        ["tmux", "-S", str(socket_path), *args],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        sys.exit(result.returncode)
    return result.stdout.strip()


def agent_command(workdir: Path, banner: str) -> str:
    return (
        "sh -lc "
        + shlex.quote(
            f"cd {shlex.quote(str(workdir))} && "
            f"printf '%s\\n' {shlex.quote(banner)}; exec sleep 600"
        )
    )


def write_visual_env(root: Path, socket_path: Path, log_dir: Path) -> None:
    VISUAL_ENV_PATH.write_text(
        f"root={root}\n"
        f"socket={socket_path}\n"
        f"log_dir={log_dir}\n",
        encoding="utf-8",
    )


capture_only = "--capture-only" in sys.argv[1:]

if not capture_only:
    log_step("Running focused render regressions")
    run(["cargo", "test", "--lib", "ui::render::tests"])

    log_step("Running live dashboard smoke")
    run(["cargo", "test", "--test", "runtime_dashboard"])

if shutil.which("vhs") is None:
    log_step("Skipping VHS capture because `vhs` is not installed")
    log_ok("UX verification complete")
    sys.exit(0)

log_step("Building foreman for VHS capture")
run(["cargo", "build"])

with tempfile.TemporaryDirectory(prefix="foreman-ux-visual-") as temp_root:
    root = Path(temp_root)
    socket_path = root / "tmux.sock"
    log_dir = root / "logs"
    log_dir.mkdir(parents=True, exist_ok=True)

    write_visual_env(root, socket_path, log_dir)

    tmux(socket_path, "-f", "/dev/null", "start-server")
    try:
        sessions = [
            ("alpha", "Claude Code ready"),
            ("beta", "Codex CLI waiting for your input"),
            ("gamma", "Pi ready for the next task"),
        ]
        for name, banner in sessions:
            workdir = root / name
            workdir.mkdir(parents=True, exist_ok=True)
            tmux(
                socket_path,
                "new-session",
                "-d",
                "-s",
                name,
                agent_command(workdir, banner),
            )

        log_step("Refreshing UX GIF and screenshots with VHS")
        run(["vhs", str(TAPE_PATH)])
    finally:
        subprocess.run(["tmux", "-S", str(socket_path), "kill-server"], check=False)

log_ok("UX verification complete")
