#!/usr/bin/env -S uv run python
# MISE description="Run foreman from source"
# MISE depends=["setup"]
import os
import sys

sys.path.insert(0, os.path.join(os.environ["MISE_PROJECT_ROOT"], "scripts"))
from lib import PROJECT_ROOT, log_step, run  # noqa: E402

log_step("Starting foreman")
cmd = ["cargo", "run", "--bin", "foreman"]
if sys.argv[1:]:
    cmd.extend(["--", *sys.argv[1:]])
run(cmd, cwd=PROJECT_ROOT)
